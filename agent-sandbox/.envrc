#!/usr/bin/env bash

# Disable gitman's local repo cache.
# When using sparse paths, gitman defaults to cloning into ~/.gitcache/*
# and making a local checkout with origin referencing that directory,
# which makes pushing changes to the remote repo more difficult.
GITMAN_CACHE_DISABLE=true
export GITMAN_CACHE_DISABLE

# Put the portable gitman shim on PATH so `gitman` always injects --depth=1 for
# the subcommands that would otherwise recurse into nested child gitman.yml
# files. direnv strips exported functions, so a PATH shim is the reliable way to
# wrap the command across shells and subprocesses.
#
# The shim is a STATIC, machine-independent artifact at scripts/bin/gitman: it
# resolves the real gitman at runtime (no hard-coded path), so its bytes — and
# therefore its sha256 — are identical on every machine this repo is synced to.
# We pin that digest here and refuse to put the shim on PATH unless it matches,
# so a corrupted or tampered shim never gets executed. Updating the shim means
# updating _shim_expected_sha256 below, which also forces a fresh `direnv allow`.
_shim_dir="${PWD}/scripts/bin"
_shim="${_shim_dir}/gitman"
# After an INTENTIONAL edit to scripts/bin/gitman, refresh this digest:
#   sha256sum scripts/bin/gitman     # run from this directory (agent-sandbox)
# Paste the new hash below, then re-run `direnv allow`.
# (On a failed check, the "actual:" value printed in the error IS the new hash.)
_shim_expected_sha256="4210e6824555b791163c159c795a7945e5d5a92970732a616d521fa33d63da0b"

if [[ ! -f "${_shim}" ]]; then
    log_error "gitman shim missing at ${_shim}; gitman will run without --depth=1 injection"
elif ! command -v gitman >/dev/null 2>&1; then
    log_error "gitman not found on PATH; install it before reloading this .envrc"
else
    _shim_actual_sha256="$(sha256sum "${_shim}" | cut -d' ' -f1)"
    if [[ "${_shim_actual_sha256}" != "${_shim_expected_sha256}" ]]; then
        log_error "gitman shim failed integrity check; refusing to add it to PATH"
        log_error "  path:     ${_shim}"
        log_error "  expected: ${_shim_expected_sha256}"
        log_error "  actual:   ${_shim_actual_sha256}"
        log_error "  if you edited the shim on purpose: set _shim_expected_sha256 in .envrc to the"
        log_error "  'actual' value above, then re-run 'direnv allow'."
    else
        chmod +x "${_shim}" 2>/dev/null || true
        PATH_add "${_shim_dir}"
        log_status "gitman shim verified (sha256 ok) and added to PATH"
    fi
fi

unset _shim_dir _shim _shim_expected_sha256 _shim_actual_sha256
