#!/usr/bin/env bash

# Disable gitman's local repo cache.
# When using sparse paths, gitman defaults to cloning into ~/.gitcache/*
# and making a local checkout with origin referencing that directory,
# which makes pushing changes to the remote repo more difficult.
GITMAN_CACHE_DISABLE=true
export GITMAN_CACHE_DISABLE

# Ensure a local PATH shim exists that forces `gitman --depth=1` on
# subcommands that accept it, preventing recursion into nested gitman.yml
# files. direnv strips exported functions, so a PATH shim is the
# reliable mechanism for wrapping the command across shells and subprocesses.
_shim_dir="$(direnv_layout_dir)/bin"
_shim="${_shim_dir}/gitman"
_real_gitman="$(command -v gitman || true)"

if [[ -z "${_real_gitman}" ]]; then
    log_error "gitman not found on PATH; install it before reloading this .envrc"
elif [[ ! -x "${_shim}" ]] || ! grep -q "GITMAN_SHIM_V3" "${_shim}" 2>/dev/null; then
    mkdir -p "${_shim_dir}"

    # Literal shim script body. No expansion happens here because the
    # heredoc terminator is quoted. Placeholder tokens get replaced below.
    _shim_body=$(cat <<'SHIM_SCRIPT'
#!/usr/bin/env bash
# GITMAN_SHIM_V3 - managed by .envrc, do not edit by hand
# Inject --depth=1 only for subcommands that accept it.

real_gitman="xxxxx_real_gitman_path_xxxxx"

# Find the first non-flag argument; that's the subcommand.
subcommand=""
for arg in "$@"; do
    case "$arg" in
        -*) ;;
        *) subcommand="$arg"; break ;;
    esac
done

case "$subcommand" in
    install|update|list)
        # Don't double up if the user already passed --depth or -d.
        for arg in "$@"; do
            case "$arg" in
                --depth|--depth=*|-d) exec "$real_gitman" "$@" ;;
            esac
        done
        # Insert --depth=1 right after the subcommand so it parses correctly.
        new_args=()
        inserted=0
        for arg in "$@"; do
            new_args+=("$arg")
            if [[ $inserted -eq 0 && "$arg" == "$subcommand" ]]; then
                new_args+=("--depth=1")
                inserted=1
            fi
        done
        exec "$real_gitman" "${new_args[@]}"
        ;;
    *)
        exec "$real_gitman" "$@"
        ;;
esac
SHIM_SCRIPT
)

    # Substitute placeholders with actual values.
    _shim_body="${_shim_body//xxxxx_real_gitman_path_xxxxx/${_real_gitman}}"

    printf '%s\n' "${_shim_body}" > "${_shim}"
    chmod +x "${_shim}"
    log_status "created gitman shim at ${_shim}"
fi

PATH_add "${_shim_dir}"

unset _shim_dir _shim _real_gitman _shim_body
