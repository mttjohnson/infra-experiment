# Dependencies installed via ansible-galaxy:
# ansible-galaxy install -r ansible_requirements.yml
/collections

# Ansible temporary files
/.ansible-facts_cache

# Ansible logs
/logs/*
!/logs/.placeholder

# Ignore temp packer inventory files
/inventories/packer-provisioner-ansible*

# Ignore restic repository password files (secret); other restic-state files
# (repo-id pins, volume sentinel ids) are non-secret and committable.
/restic-state/*.password
